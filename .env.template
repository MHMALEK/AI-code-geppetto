# ── LLM backend — change this one line to switch models ──────────────────────
# Recommended for cloud: gemini/ uses Google AI Studio (just an API key, no JSON)
LLM_MODEL=gemini/gemini-2.5-pro
# LLM_MODEL=gemini/gemini-2.0-flash         ← cheaper/faster, same API key
# LLM_MODEL=vertex_ai/gemini-2.5-pro        ← Vertex AI (needs service account JSON)
# LLM_MODEL=anthropic/claude-sonnet-4-6     ← Anthropic API
# LLM_MODEL=ollama/qwen2.5-coder:32b        ← local Ollama

# ── Google AI Studio — get key at aistudio.google.com/app/apikey ──────────────
GEMINI_API_KEY=AIza...

# ── GCP / Vertex AI (only needed if using vertex_ai/ models above) ────────────
VERTEXAI_PROJECT=your-gcp-project-id
VERTEXAI_LOCATION=us-central1

# ── Only needed if using Anthropic backend ────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Embeddings (OpenAI) ───────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_key_here
EMBED_MODEL=vertex_ai/text-embedding-004

# ── Langfuse observability (optional — delete/leave blank to disable) ─────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Paths ─────────────────────────────────────────────────────────────────────
SAMPLE_REPO_PATH=/Users/mohammadhosseinmalek/tract-projects/code-geppetto/sample-geppetto-repo
CHROMA_PATH=./data/chroma
SQLITE_PATH=./data/tasks.db

# ── Cloud deployment (Fly.io) ─────────────────────────────────────────────────
# GitHub repo the agent will clone, edit, and open PRs against
TARGET_REPO_URL=https://github.com/your-org/your-repo.git
# GitHub personal access token (needs repo + PR permissions)
GITHUB_TOKEN=ghp_...
# Git commit identity used by the agent
GIT_USER_EMAIL=geppetto@your-domain.com
GIT_USER_NAME=Geppetto

# ── Telegram bot (optional) — POST /telegram webhook ──────────────────────────
# Get token from @BotFather. Set webhook to https://your-host/telegram (HTTPS required in prod).
TELEGRAM_BOT_TOKEN=
